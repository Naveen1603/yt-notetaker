# Required: Google AI Studio / Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Alternative env name supported by the script
# GOOGLE_API_KEY=

# Optional defaults
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_REQUEST_TIMEOUT=480

# Optional: default playlist when you omit the URL argument
# YT_PLAYLIST_URL=https://www.youtube.com/playlist?list=PLxxxx
